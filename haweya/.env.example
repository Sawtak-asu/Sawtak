# Haweya Mock OAuth Server Configuration

# Server
PORT=3030
HOST=localhost

# JWT Secret (change in production!)
JWT_SECRET=haweya_dev_secret_change_in_production

# Token expiry (in seconds)
ACCESS_TOKEN_EXPIRY=3600
REFRESH_TOKEN_EXPIRY=604800

# Client credentials (for Sawtak integration)
# Add more clients as needed
ALLOWED_CLIENTS=sawtak_client:sawtak_secret,demo_client:demo_secret

# Redirect URIs (comma-separated, for validation)
ALLOWED_REDIRECT_URIS=http://localhost:3000/auth/haweya/callback,http://localhost:8000/api/auth/haweya/callback
