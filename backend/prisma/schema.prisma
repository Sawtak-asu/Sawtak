generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String  @id @default(uuid())
  email                String  @unique
  password             String?
  name                 String?
  picture              String?
  anonymous_identifier String  @unique
  role                 String  @default("user")
  is_blocked           Boolean @default(false)

  auth_provider    String  @default("email")
  auth_provider_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  complaints_identified IdentifiedComplaint[]
  admin_audits          AdminAudit[]
  votes                 ComplaintVote[]
  team_memberships      TeamMember[]
  complaint_actions     ComplaintHistory[]
  escalations_from      Escalation[]          @relation("EscalatedFrom")
  escalations_to        Escalation[]          @relation("EscalatedTo")
  reveal_requests_made     IdentityRevealRequest[] @relation("RevealRequester")
  reveal_requests_reviewed IdentityRevealRequest[] @relation("RevealReviewer")
}

model IdentifiedComplaint {
  id            String    @id @default(uuid())
  user_id       String
  title         String
  text          String
  category      String
  area          String
  directed_to   Json?
  incident_date DateTime  @default(now())
  status        String    @default("submitted")
  visibility    String    @default("private")
  evidence_urls Json?
  cosmos_tx_hash String?  @unique
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  user  User            @relation(fields: [user_id], references: [id])
  votes ComplaintVote[]

  @@index([directed_to])
  @@index([category])
}

model IndexedComplaint {
  hcs_hash             String   @id
  chain_hash           String   @unique
  chain_type           String   @default("hedera")
  anonymous_identifier String
  tracking_hash        String?
  title                String
  complaint_text       String
  category             String
  area                 String
  directed_to          Json?
  severity             String
  incident_date        DateTime
  evidence_cids        Json?
  status               String
  consensus_timestamp  DateTime
  indexed_at           DateTime @default(now())

  @@index([anonymous_identifier])
  @@index([tracking_hash])
  @@index([chain_hash])
  @@index([category])
  @@index([area])
  @@index([status])
  @@index([directed_to])
}

model IndexedStatusUpdate {
  hcs_hash            String   @id
  cosmos_tx_hash      String   @unique
  complaint_hash      String
  old_status          String
  new_status          String
  public_notes        String?
  admin_id            String
  consensus_timestamp DateTime
  sequence_number     BigInt
  indexed_at          DateTime @default(now())

  @@index([complaint_hash])
}

model AdminAudit {
  id          String   @id @default(uuid())
  admin_id    String
  action_type String
  target_id   String
  reason      String?
  timestamp   DateTime @default(now())

  admin User @relation(fields: [admin_id], references: [id])
}

model ComplaintVote {
  id           String   @id @default(uuid())
  complaint_id String
  voter_id     String
  created_at   DateTime @default(now())

  complaint IdentifiedComplaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  voter     User                @relation(fields: [voter_id], references: [id], onDelete: Cascade)

  @@unique([complaint_id, voter_id])
  @@index([complaint_id])
}

model Team {
  id         String   @id @default(uuid())
  entity_id  String   @unique
  type       String
  created_at DateTime @default(now())

  members TeamMember[]

  @@index([type])
}

model TeamMember {
  id         String   @id @default(uuid())
  user_id    String
  team_id    String
  role       String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([user_id, team_id])
  @@index([team_id])
  @@index([user_id])
}

model ComplaintHistory {
  id             String   @id @default(uuid())
  complaint_id   String
  complaint_type String
  action         String
  old_status     String?
  new_status     String?
  note           String?
  performed_by   String
  created_at     DateTime @default(now())

  performer User @relation(fields: [performed_by], references: [id])

  @@index([complaint_id])
  @@index([performed_by])
}

model Escalation {
  id             String    @id @default(uuid())
  complaint_id   String
  complaint_type String
  from_user_id   String
  to_user_id     String?
  priority       String
  note           String?
  status         String    @default("pending")
  created_at     DateTime  @default(now())
  resolved_at    DateTime?

  from_user User  @relation("EscalatedFrom", fields: [from_user_id], references: [id])
  to_user   User? @relation("EscalatedTo", fields: [to_user_id], references: [id])

  @@index([complaint_id])
  @@index([to_user_id])
  @@index([status])
}

model IdentityRevealRequest {
  id             String    @id @default(uuid())
  complaint_id   String
  complaint_type String    @default("anonymous")
  requested_by   String
  reason         String
  status         String    @default("pending")
  reviewed_by    String?
  review_note    String?
  revealed_user_id    String?
  revealed_user_name  String?
  revealed_user_email String?
  created_at     DateTime  @default(now())
  reviewed_at    DateTime?

  requester User  @relation("RevealRequester", fields: [requested_by], references: [id])
  reviewer  User? @relation("RevealReviewer", fields: [reviewed_by], references: [id])

  @@index([complaint_id])
  @@index([requested_by])
  @@index([status])
}