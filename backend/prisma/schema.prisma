generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String  @id @default(uuid())
  email                String  @unique
  password             String? // Optional for OAuth users
  name                 String? // User's display name (from OAuth)
  picture              String? // Profile picture URL (from OAuth)
  anonymous_identifier String  @unique
  role                 String  @default("user") // user, platform_admin
  is_blocked           Boolean @default(false) // Block user from platform

  // OAuth / Future Identity Provider fields
  auth_provider    String  @default("email") // email, google, github, civil_id
  auth_provider_id String? // The ID from the external provider

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  complaints_identified IdentifiedComplaint[]
  admin_audits          AdminAudit[]
  votes                 ComplaintVote[]
  team_memberships      TeamMember[]
  complaint_actions     ComplaintHistory[]
  escalations_from      Escalation[]          @relation("EscalatedFrom")
  escalations_to        Escalation[]          @relation("EscalatedTo")
  reveal_requests_made     IdentityRevealRequest[] @relation("RevealRequester")
  reveal_requests_reviewed IdentityRevealRequest[] @relation("RevealReviewer")
}

model IdentifiedComplaint {
  id            String    @id @default(uuid())
  user_id       String
  title         String
  text          String
  category      String
  area          String
  directed_to   Json? // { type: "ministry"|"governorate"|"center", ministryId?, governorateId?, centerId? }
  incident_date DateTime  @default(now())
  status        String    @default("submitted")
  visibility    String    @default("private") // private, public
  evidence_urls Json? // Array of URLs
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  user  User            @relation(fields: [user_id], references: [id])
  votes ComplaintVote[]

  @@index([directed_to]) // For admin filtering
  @@index([category])
}

model IndexedComplaint {
  hcs_hash             String   @id
  anonymous_identifier String
  tracking_hash        String? // Hashed tracking code for user lookup
  title                String
  complaint_text       String
  category             String
  area                 String
  directed_to          Json? // { type: "ministry"|"governorate"|"center", ministryId?, governorateId?, centerId? }
  severity             String
  incident_date        DateTime
  evidence_cids        Json?
  status               String
  consensus_timestamp  DateTime
  indexed_at           DateTime @default(now())

  @@index([anonymous_identifier])
  @@index([tracking_hash])
  @@index([category])
  @@index([area])
  @@index([status])
  @@index([directed_to])
}

model IndexedStatusUpdate {
  hcs_hash            String   @id
  complaint_hash      String
  old_status          String
  new_status          String
  public_notes        String?
  admin_id            String
  consensus_timestamp DateTime
  sequence_number     BigInt
  indexed_at          DateTime @default(now())

  @@index([complaint_hash])
}

model AdminAudit {
  id          String   @id @default(uuid())
  admin_id    String
  action_type String // "BAN_USER" or "DELETE_COMPLAINT"
  target_id   String // Complaint ID that was acted upon
  reason      String? // Optional reason for the action
  timestamp   DateTime @default(now())

  admin User @relation(fields: [admin_id], references: [id])
}

// Track upvotes for public identified complaints only
// Anonymous complaints cannot be upvoted, and users must be logged in to vote
model ComplaintVote {
  id           String   @id @default(uuid())
  complaint_id String // ID of the IdentifiedComplaint
  voter_id     String // User ID (required - must be logged in)
  created_at   DateTime @default(now())

  // Relations
  complaint IdentifiedComplaint @relation(fields: [complaint_id], references: [id], onDelete: Cascade)
  voter     User                @relation(fields: [voter_id], references: [id], onDelete: Cascade)

  @@unique([complaint_id, voter_id]) // One vote per user per complaint
  @@index([complaint_id])
}

// Entity/Team model (maps to egypt-locations.ts ministries/governorates/centers)
model Team {
  id         String   @id @default(uuid())
  entity_id  String   @unique // ID from egypt-locations.ts (e.g., "min_interior", "gov_cairo")
  type       String // "ministry" | "governorate" | "center"
  created_at DateTime @default(now())

  members TeamMember[]

  @@index([type])
}

// Admin-Team relationship with role type
model TeamMember {
  id         String   @id @default(uuid())
  user_id    String
  team_id    String
  role       String // "reviewer" | "manager" | "team_admin"
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)

  @@unique([user_id, team_id]) // One role per team per user
  @@index([team_id])
  @@index([user_id])
}

// Complaint action history/audit trail
model ComplaintHistory {
  id             String   @id @default(uuid())
  complaint_id   String
  complaint_type String // "identified" | "anonymous"
  action         String // "status_change" | "escalate" | "flag_inaccurate" | "flag_legal" | "identity_reveal" | "ban_user"
  old_status     String?
  new_status     String?
  note           String? // Optional note from reviewer/manager
  performed_by   String
  created_at     DateTime @default(now())

  performer User @relation(fields: [performed_by], references: [id])

  @@index([complaint_id])
  @@index([performed_by])
}

// Escalation tracking with priority and assignment
model Escalation {
  id             String    @id @default(uuid())
  complaint_id   String
  complaint_type String // "identified" | "anonymous"
  from_user_id   String // Who escalated
  to_user_id     String? // Assigned manager (optional)
  priority       String // "low" | "medium" | "high" | "urgent"
  note           String? // Reason for escalation
  status         String    @default("pending") // "pending" | "accepted" | "resolved"
  created_at     DateTime  @default(now())
  resolved_at    DateTime?

  from_user User  @relation("EscalatedFrom", fields: [from_user_id], references: [id])
  to_user   User? @relation("EscalatedTo", fields: [to_user_id], references: [id])

  @@index([complaint_id])
  @@index([to_user_id])
  @@index([status])
}

// Identity Reveal Request - Team Admin requests, Platform Admin approves
model IdentityRevealRequest {
  id             String    @id @default(uuid())
  complaint_id   String    // HCS hash of the anonymous complaint
  complaint_type String    @default("anonymous") // Always anonymous for reveal requests
  requested_by   String    // Team Admin who requested
  reason         String    // Justification for reveal
  status         String    @default("pending") // "pending" | "approved" | "rejected"
  reviewed_by    String?   // Platform Admin who reviewed
  review_note    String?   // Optional note from platform admin
  revealed_user_id    String?  // User ID if revealed (after approval)
  revealed_user_name  String?  // User name if revealed
  revealed_user_email String?  // User email if revealed
  created_at     DateTime  @default(now())
  reviewed_at    DateTime?

  requester User  @relation("RevealRequester", fields: [requested_by], references: [id])
  reviewer  User? @relation("RevealReviewer", fields: [reviewed_by], references: [id])

  @@index([complaint_id])
  @@index([requested_by])
  @@index([status])
}
