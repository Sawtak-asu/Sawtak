# ============================================
# Sawtak - Environment Variables Template
# ============================================

# --- Blockchain (Cosmos) ---
COSMOS_BACKEND_MNEMONIC="your mnemonic here"
SAWTAK_BACKEND_PUBKEY="your pubkey here"
COSMOS_CHAIN_ID=sawtak-testnet-1

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sawtak-public-evidence
R2_PUBLIC_URL=

# --- Storage (Pinata IPFS) ---
# NOTE: Using PINATA_API_SECERT_KEY (with typo) to match current codebase
PINATA_API_KEY=
PINATA_API_SECERT_KEY=
PINATA_JWT=

# --- Database (Postgres) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sawtak

# --- Redis ---
REDIS_PASSWORD=

# --- Auth & Identity ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
HAWEYA_ISSUER_URL=http://localhost:3030
HAWEYA_CLIENT_ID=sawtak_client
HAWEYA_CLIENT_SECRET=sawtak_secret
JWT_SECRET=your_jwt_secret

# --- Encryption ---
ENCRYPTION_KEY=
PLATFORM_SECRET=
BACKEND_PRIVATE_KEY_PEM=

# --- Proxy ---
PROXY_SECRET=
