# ============================================
# Sawtak Environment Variables Example
# ============================================
# Copy this file to .env and fill in the values
# ============================================

# ===================
# General
# ===================
NODE_ENV=development
DOMAIN=sawtak.example.com
FRONTEND_URL=http://localhost:3000

# ===================
# Database
# ===================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_DB=sawtak

# ===================
# JWT & Security
# ===================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secure-jwt-secret-key-change-this-in-production
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
PLATFORM_SECRET=generate-a-secure-random-string

# ===================
# Cloudflare R2 Storage
# ===================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=sawtak-public-evidence
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# ===================
# Hedera Hashgraph
# ===================
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.your-account-id
HEDERA_OPERATOR_KEY=your-hedera-private-key
HEDERA_TOPIC_COMPLAINTS=0.0.your-complaints-topic-id
HEDERA_TOPIC_STATUS=0.0.your-status-topic-id

# ===================
# IPFS (Web3.Storage)
# ===================
WEB3_STORAGE_TOKEN=your-web3-storage-token

# ===================
# Google OAuth
# ===================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ===================
# Frontend API
# ===================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===================
# Monitoring (Grafana + Prometheus)
# ===================
# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
# Public URL for Grafana (used for links in emails, etc.)
GRAFANA_ROOT_URL=http://localhost:3001

# ===================
# Production Only (Traefik)
# ===================
ACME_EMAIL=admin@example.com
# Generate with: echo $(htpasswd -nb admin password) | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...hashed-password...

