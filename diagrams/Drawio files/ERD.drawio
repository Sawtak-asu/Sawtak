        <mxCell id="t_indexed" value="&lt;b&gt;Indexed Complaints&lt;/b&gt;&lt;hr&gt;- hash (PK)&lt;br&gt;- title / description&lt;br&gt;- category&lt;br&gt;- status&lt;br&gt;- sender_pseudonym&lt;br&gt;- ipfs_cid" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffffff;strokeColor=#0052cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="320" width="200" height="150" as="geometry" />
        </mxCell>
        <mxCell id="t_audit" value="&lt;b&gt;Admin Audit Logs&lt;/b&gt;&lt;hr&gt;- id (PK)&lt;br&gt;- admin_id (FK)&lt;br&gt;- action&lt;br&gt;- target_type / id&lt;br&gt;- timestamp" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffffff;strokeColor=#0052cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="650" y="100" width="200" height="150" as="geometry" />
        </mxCell>
        <mxCell id="t_reveal" value="&lt;b&gt;Identity Reveal Requests&lt;/b&gt;&lt;hr&gt;- id (PK)&lt;br&gt;- complaint_id&lt;br&gt;- requested_by (FK)&lt;br&gt;- approved_by (FK)&lt;br&gt;- status / reason" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffffff;strokeColor=#0052cc;strokeWidth=2;" vertex="1" parent="1">
