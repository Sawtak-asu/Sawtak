        <mxCell id="t_identified" value="&lt;b&gt;Identified Complaints&lt;/b&gt;&lt;hr&gt;- id (PK)&lt;br&gt;- user_id (FK)&lt;br&gt;- title / description&lt;br&gt;- category&lt;br&gt;- status&lt;br&gt;- directed_to" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffffff;strokeColor=#0052cc;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="350" y="100" width="200" height="150" as="geometry" />
        </mxCell>
        <mxCell id="t_tracking" value="&lt;b&gt;Anonymous Tracking&lt;/b&gt;&lt;hr&gt;- id (PK)&lt;br&gt;- user_id (FK)&lt;br&gt;- tracking_hash (UNIQUE)&lt;br&gt;- encrypted_payload&lt;br&gt;- created_at" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffffff;strokeColor=#0052cc;strokeWidth=2;" vertex="1" parent="1">
