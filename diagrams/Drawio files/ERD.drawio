          <mxGeometry x="50" y="20" width="400" height="30" as="geometry" />
        </mxCell>
        <!-- Tables -->
        <mxCell id="t_users" value="&lt;b&gt;Users&lt;/b&gt;&lt;hr&gt;- id (PK)&lt;br&gt;- email&lt;br&gt;- password_hash&lt;br&gt;- anonymous_identifier&lt;br&gt;- role&lt;br&gt;- created_at" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffffff;strokeColor=#0052cc;strokeWidth=2;" vertex="1" parent="1">
